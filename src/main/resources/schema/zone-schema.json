{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VillageZoneConfig",
  "description": "Configuration des paliers de zone village — zone.yml (plugin Survi).",
  "type": "object",
  "required": ["stages"],
  "additionalProperties": false,
  "properties": {
    "stages": {
      "type": "array",
      "description": "Paliers de zone, triés par after-hours croissant. Premier palier obligatoirement à after-hours = 0.",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/stage"
      }
    }
  },
  "definitions": {
    "stage": {
      "type": "object",
      "description": "Un palier de zone village.",
      "required": ["after-hours", "center-x", "center-z", "half-width", "half-depth", "spawn", "portal"],
      "additionalProperties": false,
      "properties": {
        "after-hours": {
          "type": "number",
          "minimum": 0,
          "description": "Heures réelles écoulées depuis le démarrage avant activation de ce palier."
        },
        "center-x": {
          "type": "integer",
          "description": "Coordonnée X du centre de la zone rectangulaire."
        },
        "center-z": {
          "type": "integer",
          "description": "Coordonnée Z du centre de la zone rectangulaire."
        },
        "half-width": {
          "type": "integer",
          "minimum": 1,
          "description": "Demi-largeur de la zone sur l'axe X (en blocs depuis le centre)."
        },
        "half-depth": {
          "type": "integer",
          "minimum": 1,
          "description": "Demi-profondeur de la zone sur l'axe Z (en blocs depuis le centre)."
        },
        "spawn": {
          "$ref": "#/definitions/spawn"
        },
        "portal": {
          "$ref": "#/definitions/portal"
        }
      }
    },
    "spawn": {
      "type": "object",
      "description": "Point de spawn Village pour ce palier.",
      "required": ["x", "y", "z"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "z": { "type": "integer" },
        "yaw":   { "type": "number" },
        "pitch": { "type": "number" }
      }
    },
    "portal": {
      "type": "object",
      "description": "Coordonnées intérieures (fakeblocks) du portail Village pour ce palier.",
      "required": ["min-x", "min-y", "min-z", "max-x", "max-y", "max-z"],
      "additionalProperties": false,
      "properties": {
        "min-x": { "type": "integer" },
        "min-y": { "type": "integer" },
        "min-z": { "type": "integer" },
        "max-x": { "type": "integer" },
        "max-y": { "type": "integer" },
        "max-z": { "type": "integer" }
      }
    }
  }
}