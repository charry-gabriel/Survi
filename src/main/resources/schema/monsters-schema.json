  "definitions": {
    "mobConfig": {
      "type": "object",
      "description": "Configuration complète d'un type de mob.",
      "additionalProperties": false,
      "properties": {
        "stats": {
          "type": "object",
          "description": "Stats scalables via des attributs Bukkit. Formule exponentielle par palier (voir statConfig).",
          "additionalProperties": false,
          "properties": {
            "max-health": {
              "$ref": "#/definitions/statConfig",
              "description": "PV max. Vanilla zombie = 20."
            },
            "attack-damage": {
              "$ref": "#/definitions/statConfig",
              "description": "Dégâts de base par frappe."
            },
            "movement-speed": {
              "$ref": "#/definitions/statConfig",
              "description": "Vitesse de déplacement. Vanilla zombie ≈ 0.23."
            },
            "scale": {
              "$ref": "#/definitions/statConfig",
              "description": "Taille relative. 1.0 = normal, 2.0 = deux fois plus grand."
            },
            "follow-range": {
              "$ref": "#/definitions/statConfig",
              "description": "Distance de détection du joueur en blocs."
            },
            "armor": {
              "$ref": "#/definitions/statConfig",
              "description": "Points d'armure naturels."
            },
            "knockback-resistance": {
              "$ref": "#/definitions/statConfig",
              "description": "Résistance au recul (0.0 à 1.0)."
            }
          }
        },
        "explosion-radius": {
          "allOf": [
            {
              "$ref": "#/definitions/linearStatConfig"
            }
          ],
          "description": "Rayon d'explosion scalé (Creeper uniquement). Formule linéaire : base + (level-1) × per-level. Vanilla = 3."
        },
        "fuse-ticks": {
          "$ref": "#/definitions/fuseConfig"
        },
        "potion-effects": {
          "type": "array",
          "description": "Effets de potion appliqués à chaque attaque du mob scalé.",
          "items": {
            "$ref": "#/definitions/potionEffectConfig"
          }
        }
      }
    },
    "statConfig": {
      "type": "object",
      "description": "Stat exponentielle par palier. Formule : tierBase × (1 + (peak-ratio − 1) × t^exponent) où tierBase = base × tier-multiplier^tier et t ∈ [0, 1] dans le palier.",
      "required": [
        "base",
        "peak-ratio"
      ],
      "additionalProperties": false,
      "properties": {
        "base": {
          "type": "number",
          "description": "Valeur au niveau 1 (début du palier 0).",
          "minimum": 0
        },
        "peak-ratio": {
          "type": "number",
          "description": "Multiplicateur atteint au pic de chaque palier (base × peak-ratio = valeur max du palier). Valeur < 1.0 = la stat diminue au fil du palier (ex. taille Creeper).",
          "minimum": 0.01
        },
        "tier-multiplier": {
          "type": "number",
          "description": "Multiplicateur appliqué à la base à chaque nouveau palier. Défaut : 2.0. > 1 = monte chaque palier, < 1 = descend.",
          "minimum": 0.01,
          "default": 2.0
        },
        "exponent": {
          "type": "number",
          "description": "Courbure de la croissance dans le palier. 1.0 = linéaire, 3.0 = cubique (défaut). Plus la valeur est haute, plus la montée est lente au début et rapide à la fin du palier.",
          "minimum": 0.1,
          "default": 3.0
        }
      }
    },
    "linearStatConfig": {
      "type": "object",
      "description": "Stat linéaire (pour explosion-radius) : valeur = base + (level − 1) × per-level.",
      "required": [
        "base",
        "per-level"
      ],
      "additionalProperties": false,
      "properties": {
        "base": {
          "type": "number",
          "description": "Valeur au niveau 1."
        },
        "per-level": {
          "type": "number",
          "description": "Incrément ajouté par niveau supplémentaire. Peut être négatif."
        }
      }
    },
    "fuseConfig": {
      "type": "object",
      "description": "Durée de mèche du Creeper. Formule : max(min, base + (level - 1) * per-level). Vanilla = 30 ticks.",
      "required": [
        "base",
        "per-level"
      ],
      "additionalProperties": false,
      "properties": {
        "base": {
          "type": "number",
          "description": "Durée de base en ticks. Vanilla = 30."
        },
        "per-level": {
          "type": "number",
          "description": "Variation par niveau. Valeur négative = explosion plus rapide."
        },
        "min": {
          "type": "integer",
          "description": "Plancher de sécurité en ticks (jamais moins).",
          "minimum": 1
        }
      }
    },
    "potionEffectConfig": {
      "type": "object",
      "description": "Effet de potion appliqué à l'attaque d'un mob scalé.",
      "required": [
        "type",
        "min-mob-level",
        "duration-base",
        "duration-per-level",
        "amplifier-upgrade-every",
        "chance-base",
        "chance-per-level",
        "max-chance"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Nom de l'effet de potion (PotionEffectType, ex : POISON, WITHER, BLINDNESS).",
          "enum": [
            "ABSORPTION",
            "BAD_OMEN",
            "BLINDNESS",
            "CONDUIT_POWER",
            "DARKNESS",
            "DOLPHINS_GRACE",
            "FIRE_RESISTANCE",
            "GLOWING",
            "HASTE",
            "HEALTH_BOOST",
            "HERO_OF_THE_VILLAGE",
            "HUNGER",
            "INSTANT_DAMAGE",
            "INSTANT_HEALTH",
            "INVISIBILITY",
            "JUMP_BOOST",
            "LEVITATION",
            "LUCK",
            "MINING_FATIGUE",
            "NAUSEA",
            "NIGHT_VISION",
            "POISON",
            "REGENERATION",
            "RESISTANCE",
            "SATURATION",
            "SLOWNESS",
            "SLOW_FALLING",
            "SPEED",
            "STRENGTH",
            "TRIAL_OMEN",
            "UNLUCK",
            "WATER_BREATHING",
            "WEAKNESS",
            "WIND_CHARGED",
            "WITHER"
          ]
        },
        "min-mob-level": {
          "type": "integer",
          "description": "Niveau minimal du mob à partir duquel l'effet est actif.",
          "minimum": 1
        },
        "duration-base": {
          "type": "integer",
          "description": "Durée de base de l'effet en ticks (20 ticks = 1 s).",
          "minimum": 0
        },
        "duration-per-level": {
          "type": "number",
          "description": "Ticks supplémentaires ajoutés par niveau du mob."
        },
        "amplifier-upgrade-every": {
          "type": "integer",
          "description": "Tous les N niveaux, l'amplificateur augmente de 1 (niveau I → II → III…).",
          "minimum": 1
        },
        "chance-base": {
          "type": "number",
          "description": "Probabilité de base d'appliquer l'effet (0.0 à 1.0).",
          "minimum": 0,
          "maximum": 1
        },
        "chance-per-level": {
          "type": "number",
          "description": "Augmentation de la probabilité par niveau (peut être 0)."
        },
        "max-chance": {
          "type": "number",
          "description": "Probabilité maximale plafond (0.0 à 1.0).",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}