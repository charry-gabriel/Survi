{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RecipesConfig",
  "type": "object",
  "description": "Configuration file that holds custom crafting recipes as used by the Survi plugin.",
  "required": ["new_recipes"],
  "properties": {
    "new_recipes": {
      "description": "Map of internal recipe key -> recipe definition.",
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/recipe" }
    },
    "old_recipes": {
      "description": "Array of namespaced keys of vanilla recipes that should be disabled (e.g. minecraft:iron_helmet).",
      "type": "array",
      "items": {
        "type": "string",
        "examples": ["minecraft:iron_helmet", "minecraft:diamond_sword"]
      }
    }
  },

  "definitions": {
    "recipe": {
      "type": "object",
      "required": ["category", "result"],
      "properties": {
        "category": {
          "type": "string",
          "description": "Corresponds to org.bukkit.inventory.recipe.CraftingBookCategory enum value.",
          "enum": [
            "BUILDING",
            "REDSTONE",
            "EQUIPMENT",
            "MISC"
          ]
        },
        "result": {
          "description": "Bukkit Material ou nom d'un Custom Item.",
          "anyOf": [
            { "$ref": "#/definitions/CustomItem" },
            { "$ref": "#/definitions/Material" }
          ]
        },
        "ingredients": {
          "type": "array",
          "description": "Exactly 9 material names (row-major 3x3 grid). Use 'AIR' for empty slot.",
          "minItems": 9,
          "maxItems": 9,
          "items": {
            "$ref": "#/definitions/Material"
          }
        },
        "roles": {
          "type": "array",
          "description": "Roles for recipe permissions",
          "items": {
            "type": "string",
            "enum": ["MINEUR", "ENCHANTER"]
          }
        },
        "tiers": {
          "type": "array",
          "description": "Tiers for recipe categorization",
          "items": {
            "type": "string",
            "enum": ["CHAINMAIL", "IRON", "GOLD", "DIAMOND"]
          }
        },
        "categories": {
          "type": "array",
          "description": "Categories for recipe categorization",
          "items": {
            "type": "string",
            "enum": ["ARMOR", "WEAPON", "MISC", "GROWTH", "TOOL"]
          }
        },
        "shape": {
          "type": "array",
          "description": "1 to 3 strings, each 1-3 characters, representing crafting grid rows.",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3
          }
        },
        "keys": {
          "type": "object",
          "description": "Mapping of single-character symbols used in shape to Bukkit Material names.",
          "minProperties": 1,
          "propertyNames": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1
          },
          "additionalProperties": { "$ref": "#/definitions/Material" }
        }
      },
      "oneOf": [
        { "required": ["ingredients"] },
        { "required": ["shape", "keys"] }
      ],
      "additionalProperties": false
    },
    "Material": {
      "type": "string",
      "description": "Nom du matériel Bukkit (ex: IRON_INGOT, EMERALD). Utilisez 'AIR' pour un emplacement vide.",
      "examples": ["IRON_INGOT", "GOLD_INGOT", "DIAMOND", "EMERALD", "STICK", "IRON_BLOCK", "AIR"]
    },
    "CustomItem": {
      "type": "string",
      "description": "L'identifiant de l'item personnalisé défini dans ECustomItem.java",
      "enum": [
        "FISHING_D_ROD",
        "AIR_FORCE",
        "MINEUR",
        "ENDIALE",
        "TERMINATOR",
        "SEX_ON_THE_BEACH",
        "PORN_STAR_MARTINI",
        "SHOOTER_ORGASM",
        "HEALING_ARROW",
        "SPICY_SWEET_DREAMS_TICKET",
        "CLE00",
        "CLE01",
        "CLE02",
        "CLE11",
        "CLE12",
        "CLE13",
        "CLE14",
        "CLE15",
        "CLE16",
        "CLE31",
        "CLE32",
        "GROWTH_PICKAXE",
        "GROWTH_SWORD",
        "MUFFIN",
        "UNBREAKING3",
        "MENDING",
        "CHANGER_ROLE"
      ]
    }
  },
  "additionalProperties": false
}
