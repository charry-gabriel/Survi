{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "jobs.yml",
  "description": "Configuration des métiers — tableaux de 11 valeurs (index = niveau 0 à 10). Valeur -1 dans un tableau entier = illimité / aucun effet.",
  "type": "object",
  "required": ["drop-multiplier", "lumberjack", "farmer", "enchanter", "fisherman", "explorer"],
  "additionalProperties": false,
  "properties": {

    "drop-multiplier": {
      "type": "array",
      "description": "Multiplicateur de drops partagé (MINER, LUMBERJACK, FARMER). Index = niveau 0 à 10.",
      "minItems": 11, "maxItems": 11,
      "items": { "type": "number", "minimum": 0 }
    },

    "lumberjack": {
      "type": "object",
      "required": ["charcoal-chance", "apple-leaf-chance", "fire-damage-multiplier", "tree-feller-extra-logs", "fire-resistance-ticks"],
      "additionalProperties": false,
      "properties": {
        "charcoal-chance":        { "$ref": "#/definitions/probability-array" },
        "apple-leaf-chance":      { "$ref": "#/definitions/probability-array" },
        "fire-damage-multiplier": { "$ref": "#/definitions/non-negative-number-array" },
        "tree-feller-extra-logs": { "$ref": "#/definitions/non-negative-int-array" },
        "fire-resistance-ticks":  { "$ref": "#/definitions/non-negative-int-array" }
      }
    },

    "farmer": {
      "type": "object",
      "required": ["crop-growth-allow-chance", "crop-extra-growth-chance", "crop-third-tick-chance-at-max"],
      "additionalProperties": false,
      "properties": {
        "crop-growth-allow-chance":     { "$ref": "#/definitions/probability-array" },
        "crop-extra-growth-chance":     { "$ref": "#/definitions/probability-array" },
        "crop-third-tick-chance-at-max": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Probabilité d'un 3e tick bonus au niveau maximum."
        }
      }
    },

    "enchanter": {
      "type": "object",
      "required": ["durability-loss-multiplier", "anvil-max-xp-cost", "repair-per-xp"],
      "additionalProperties": false,
      "properties": {
        "durability-loss-multiplier": { "$ref": "#/definitions/non-negative-number-array" },
        "anvil-max-xp-cost": {
          "type": "array",
          "description": "Coût XP maximum pour une opération d'enclume par niveau. -1 = illimité.",
          "minItems": 11, "maxItems": 11,
          "items": { "type": "integer", "minimum": -1 }
        },
        "repair-per-xp": {
          "type": "array",
          "description": "Durabilité réparée par point d'XP gagné (0 = réparation désactivée à ce niveau).",
          "minItems": 11, "maxItems": 11,
          "items": { "type": "integer", "minimum": 0 }
        }
      }
    },

    "fisherman": {
      "type": "object",
      "required": [
        "vanilla-min-wait-ticks", "vanilla-max-wait-ticks",
        "fishing-wait-multiplier", "loot-multiplier",
        "dirt-chance", "treasure-penalty",
        "pressure-safe-depth", "pressure-damage",
        "swim-speed-amplifier", "underwater-haste-amplifier",
        "effect-duration-ticks"
      ],
      "additionalProperties": false,
      "properties": {
        "vanilla-min-wait-ticks":   { "type": "integer", "minimum": 1 },
        "vanilla-max-wait-ticks":   { "type": "integer", "minimum": 1 },
        "fishing-wait-multiplier":  { "$ref": "#/definitions/non-negative-number-array" },
        "loot-multiplier":          { "$ref": "#/definitions/non-negative-number-array" },
        "dirt-chance": {
          "$ref": "#/definitions/probability-array",
          "description": "Probabilité de remplacer tout item pêché par une dirt par niveau. Tombe à 0 au niveau 7."
        },
        "treasure-penalty": {
          "$ref": "#/definitions/probability-array",
          "description": "Malus supplémentaire sur les trésors (après dirt-chance). Tombe à 0 au niveau 6."
        },
        "pressure-safe-depth": {
          "type": "array",
          "description": "Profondeur maximale sûre en blocs par niveau. -1 = aucun dégât de pression.",
          "minItems": 11, "maxItems": 11,
          "items": { "type": "integer", "minimum": -1 }
        },
        "pressure-damage": {
          "type": "number", "minimum": 0,
          "description": "Dégâts infligés par la pression sous-marine (en demi-cœurs)."
        },
        "swim-speed-amplifier":       { "$ref": "#/definitions/non-negative-int-array" },
        "underwater-haste-amplifier": { "$ref": "#/definitions/non-negative-int-array" },
        "effect-duration-ticks": { "type": "integer", "minimum": 1 }
      }
    },

    "explorer": {
      "type": "object",
      "required": ["safe-fall-distance"],
      "additionalProperties": false,
      "properties": {
        "safe-fall-distance": {
          "type": "array",
          "description": "Distance de chute sécurisée en blocs par niveau. Le modifier appliqué = valeur - 3.0 (base vanilla).",
          "minItems": 11, "maxItems": 11,
          "items": { "type": "number" }
        }
      }
    }
  },

  "definitions": {
    "non-negative-number-array": {
      "type": "array",
      "minItems": 11, "maxItems": 11,
      "items": { "type": "number", "minimum": 0 }
    },
    "probability-array": {
      "type": "array",
      "minItems": 11, "maxItems": 11,
      "items": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "non-negative-int-array": {
      "type": "array",
      "minItems": 11, "maxItems": 11,
      "items": { "type": "integer", "minimum": 0 }
    }
  }
}