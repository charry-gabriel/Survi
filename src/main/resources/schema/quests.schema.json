{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "quests": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["MINE", "KILL", "BREED", "FISH", "SHEAR", "CRAFT", "SMELT"]
          },
          "difficulty": {
            "type": "string",
            "enum": ["COMMON", "RARE", "LEGENDARY"]
          },
          "target": {
            "type": ["string", "null"],
            "description": "Matériel (MINE/CRAFT/SMELT) ou EntityType (KILL/SHEAR/BREED). Null pour FISH.",
            "examples": ["COBBLESTONE", "ZOMBIE", "COW", "IRON_ORE", "DIAMOND_ORE", "OAK_LOG"]
          },
          "goal": { "type": "integer", "minimum": 1 },
          "reputation_reward": { "type": "integer", "minimum": 0 },
          "rewards": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Nom de l'effet de potion (ex: speed, haste, strength)",
                  "enum": [
                    "speed",
                    "slowness",
                    "haste",
                    "mining_fatigue",
                    "strength",
                    "instant_health",
                    "instant_damage",
                    "jump_boost",
                    "regeneration",
                    "resistance",
                    "fire_resistance",
                    "water_breathing",
                    "invisibility",
                    "blindness",
                    "night_vision",
                    "hunger",
                    "weakness",
                    "poison",
                    "wither",
                    "health_boost",
                    "absorption",
                    "saturation",
                    "glowing",
                    "levitation",
                    "luck",
                    "unluck",
                    "slow_falling",
                    "conduit_power",
                    "dolphins_grace",
                    "bad_omen",
                    "hero_of_the_village",
                    "darkness"
                  ]
                },
                "duration": { "type": "integer", "minimum": 1, "description": "Durée en ticks (20 ticks = 1 seconde)" },
                "amplifier": { "type": "integer", "minimum": 0, "description": "Niveau de l'effet (0 = Niveau I)" }
              },
              "required": ["type", "duration", "amplifier"]
            }
          }
        },
        "required": ["id", "name", "description", "type", "difficulty", "goal", "reputation_reward", "rewards"]
      }
    }
  },
  "required": ["quests"]
}
