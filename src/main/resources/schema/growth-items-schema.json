{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Growth Item Config",
  "type": "object",
  "required": ["id", "eventType", "tiers"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Identifiant ECustomItem (ex. GROWTH_CASQUE_MINEUR)"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "BlockBreakEvent",
        "OreBreakEvent",
        "CropBreakEvent",
        "NewBiomeEvent",
        "NewMobTypeKillEvent"
      ]
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/tier" }
    },
    "periodicEffects": {
      "type": "array",
      "items": { "$ref": "#/definitions/periodic" }
    }
  },

  "definitions": {

    "tier": {
      "type": "object",
      "required": ["requiredUses", "effects"],
      "additionalProperties": false,
      "properties": {
        "requiredUses": { "type": "integer", "minimum": 1 },
        "effects":      { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/effect" } }
      }
    },

    "periodic": {
      "type": "object",
      "required": ["everyUses", "effects"],
      "additionalProperties": false,
      "properties": {
        "everyUses": { "type": "integer", "minimum": 1 },
        "effects":   { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/effect" } }
      }
    },

    "effect": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["name", "message", "haste", "potion", "add_enchantment", "set_attribute"]
        },
        "value":          { "type": "string",  "description": "[name / message]" },
        "seconds":        { "type": "integer", "minimum": 1,  "description": "[haste / potion]" },
        "effect":         { "type": "string",  "description": "[potion] clé PotionEffectType (ex. speed, strength, night_vision)" },
        "amplifier":      { "type": "integer", "minimum": 0,  "description": "[potion] 0 = niveau I, 1 = niveau II" },
        "enchantment":    { "type": "string",  "description": "[add_enchantment] clé minecraft (ex. fortune, sharpness)" },
        "amount":         { "type": "integer", "minimum": 1,  "description": "[add_enchantment] niveaux à ajouter" },
        "attribute": {
          "type": "string",
          "description": "[set_attribute]",
          "enum": [
            "mining_efficiency", "movement_speed", "attack_damage", "attack_speed",
            "armor", "armor_toughness", "max_health", "block_break_speed",
            "luck", "knockback_resistance"
          ]
        },
        "attributeValue": { "type": "number",  "description": "[set_attribute] valeur totale (remplace l'existant)" },
        "operation": {
          "type": "string",
          "enum": ["ADD_NUMBER", "ADD_SCALAR", "MULTIPLY_SCALAR_1"],
          "description": "[set_attribute]"
        },
        "slot": {
          "type": "string",
          "enum": ["HEAD", "CHEST", "LEGS", "FEET", "HAND", "OFF_HAND", "ARMOR", "ANY"],
          "description": "[set_attribute]"
        }
      },
      "if":   { "properties": { "type": { "const": "name" } } },
      "then": { "required": ["value"] },
      "else": {
        "if":   { "properties": { "type": { "const": "message" } } },
        "then": { "required": ["value"] },
        "else": {
          "if":   { "properties": { "type": { "const": "haste" } } },
          "then": { "required": ["seconds"] },
          "else": {
            "if":   { "properties": { "type": { "const": "potion" } } },
            "then": { "required": ["effect", "seconds"] },
            "else": {
              "if":   { "properties": { "type": { "const": "add_enchantment" } } },
              "then": { "required": ["enchantment", "amount"] },
              "else": {
                "if":   { "properties": { "type": { "const": "set_attribute" } } },
                "then": { "required": ["attribute", "attributeValue", "operation", "slot"] }
              }
            }
          }
        }
      }
    }
  }
}