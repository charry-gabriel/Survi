{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Growth Item Config",
  "type": "object",
  "required": ["id", "eventType", "tiers"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Identifiant ECustomItem (ex. GROWTH_CASQUE_MINEUR)"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "BlockBreakEvent",
        "OreBreakEvent",
        "CropBreakEvent",
        "LogBreakEvent",
        "FishCatchEvent",
        "XpGainEvent",
        "NewBiomeEvent",
        "NewMobTypeKillEvent"
      ]
    },
    "baseEffects": {
      "type": "array",
      "description": "Effets persistants appliqués à la création de l'item ET réappliqués à chaque reload (avant les paliers). Seuls name, add_enchantment, set_attribute et permanent_potion sont acceptés — message, haste et potion seraient silencieusement ignorés au reload.",
      "items": { "$ref": "#/definitions/baseEffect" }
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/tier" }
    },
    "periodicEffects": {
      "type": "array",
      "items": { "$ref": "#/definitions/periodic" }
    }
  },

  "definitions": {

    "tier": {
      "type": "object",
      "required": ["requiredUses", "effects"],
      "additionalProperties": false,
      "properties": {
        "requiredUses": { "type": "integer", "minimum": 1 },
        "effects":      { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/effect" } }
      }
    },

    "periodic": {
      "type": "object",
      "required": ["everyUses", "effects"],
      "additionalProperties": false,
      "properties": {
        "everyUses": { "type": "integer", "minimum": 1 },
        "effects":   { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/effect" } }
      }
    },

    "baseEffect": {
      "type": "object",
      "required": ["type"],
      "description": "Effet de base — seuls les types persistants sont autorisés.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["name", "add_enchantment", "set_attribute", "permanent_potion"],
          "description": "message / haste / potion sont transitoires et ne sont pas autorisés dans baseEffects (ignorés au reload). permanent_potion est accepté : actif tant que l'item est porté, réappliqué après reload."
        },
        "value":          { "type": "string",  "description": "[name]" },
        "effect":         { "type": "string",  "description": "[permanent_potion] clé PotionEffectType (ex. night_vision, haste, speed)" },
        "amplifier":      { "type": "integer", "minimum": 0, "description": "[permanent_potion] 0 = niveau I, 1 = niveau II" },
        "enchantment":    { "type": "string",  "description": "[add_enchantment] clé minecraft (ex. fortune, efficiency)" },
        "amount":         { "type": "integer", "minimum": 1,  "description": "[add_enchantment] niveaux à ajouter" },
        "attribute": {
          "type": "string",
          "description": "[set_attribute]",
          "enum": [
            "armor",
            "armor_toughness",
            "attack_damage",
            "attack_speed",
            "block_break_speed",
            "knockback_resistance",
            "luck",
            "max_health",
            "mining_efficiency",
            "movement_speed"
          ]
        },
        "attributeValue": { "type": "number",  "description": "[set_attribute] valeur de base (remplacée par les paliers)" },
        "operation": {
          "type": "string",
          "enum": ["ADD_NUMBER", "ADD_SCALAR", "MULTIPLY_SCALAR_1"],
          "description": "[set_attribute]"
        },
        "slot": {
          "type": "string",
          "enum": ["HEAD", "CHEST", "LEGS", "FEET", "HAND", "OFF_HAND", "ARMOR", "ANY"],
          "description": "[set_attribute]"
        }
      },
      "if":   { "properties": { "type": { "const": "name" } } },
      "then": { "required": ["value"] },
      "else": {
        "if":   { "properties": { "type": { "const": "permanent_potion" } } },
        "then": { "required": ["effect"] },
        "else": {
          "if":   { "properties": { "type": { "const": "add_enchantment" } } },
          "then": { "required": ["enchantment", "amount"] },
          "else": {
            "if":   { "properties": { "type": { "const": "set_attribute" } } },
            "then": { "required": ["attribute", "attributeValue", "operation", "slot"] }
          }
        }
      }
    },

    "effect": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "name", "message", "haste", "potion", "permanent_potion",
            "fire_enemies", "add_enchantment", "set_attribute"
          ]
        },
        "value":          { "type": "string",  "description": "[name / message]" },
        "seconds":        { "type": "integer", "minimum": 1,  "description": "[haste / potion / fire_enemies]" },
        "effect":         { "type": "string",  "description": "[potion / permanent_potion] clé PotionEffectType (ex. speed, strength, night_vision)" },
        "amplifier":      { "type": "integer", "minimum": 0,  "description": "[potion / permanent_potion] 0 = niveau I, 1 = niveau II" },
        "enchantment":    { "type": "string",  "description": "[add_enchantment] clé minecraft (ex. fortune, sharpness)" },
        "amount":         { "type": "integer", "minimum": 1,  "description": "[add_enchantment] niveaux à ajouter" },
        "attribute": {
          "type": "string",
          "description": "[set_attribute]",
          "enum": [
            "armor",
            "armor_toughness",
            "attack_damage",
            "attack_speed",
            "block_break_speed",
            "knockback_resistance",
            "luck",
            "max_health",
            "mining_efficiency",
            "movement_speed"
          ]
        },
        "attributeValue": { "type": "number",  "description": "[set_attribute] valeur totale (remplace l'existant)" },
        "operation": {
          "type": "string",
          "enum": ["ADD_NUMBER", "ADD_SCALAR", "MULTIPLY_SCALAR_1"],
          "description": "[set_attribute]"
        },
        "slot": {
          "type": "string",
          "enum": ["HEAD", "CHEST", "LEGS", "FEET", "HAND", "OFF_HAND", "ARMOR", "ANY"],
          "description": "[set_attribute]"
        }
      },
      "if":   { "properties": { "type": { "const": "name" } } },
      "then": { "required": ["value"] },
      "else": {
        "if":   { "properties": { "type": { "const": "message" } } },
        "then": { "required": ["value"] },
        "else": {
          "if":   { "properties": { "type": { "const": "haste" } } },
          "then": { "required": ["seconds"] },
          "else": {
            "if":   { "properties": { "type": { "const": "potion" } } },
            "then": { "required": ["effect", "seconds"] },
            "else": {
              "if":   { "properties": { "type": { "const": "permanent_potion" } } },
              "then": { "required": ["effect"] },
              "else": {
                "if":   { "properties": { "type": { "const": "fire_enemies" } } },
                "then": { "required": ["seconds"] },
                "else": {
                  "if":   { "properties": { "type": { "const": "add_enchantment" } } },
                  "then": { "required": ["enchantment", "amount"] },
                  "else": {
                    "if":   { "properties": { "type": { "const": "set_attribute" } } },
                    "then": { "required": ["attribute", "attributeValue", "operation", "slot"] }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}