{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TraderConfig",
  "type": "object",
  "required": [
    "nameId",
    "displayName",
    "type",
    "profession",
    "openMessage",
    "recipes"
  ],
  "properties": {
    "nameId": { "type": "string" },
    "displayName": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "DESERT",
        "JUNGLE",
        "PLAINS",
        "SAVANNA",
        "SNOW",
        "SWAMP",
        "TAIGA"
      ]
    },
    "profession": {
      "type": "string",
      "enum": [
        "ARMORER",
        "BUTCHER",
        "CARTOGRAPHER",
        "CLERIC",
        "FARMER",
        "FISHERMAN",
        "FLETCHER",
        "LEATHERWORKER",
        "LIBRARIAN",
        "MASON",
        "NITWIT",
        "NONE",
        "SHEPHERD",
        "TOOLSMITH",
        "WEAPONSMITH"
      ]
    },
    "job": {
      "type": "string",
      "enum": [
        "MINEUR",
        "FERMIER",
        "COMBATANT",
        "ALCHIMISTE",
        "ENCHANTEUR",
        "FORGERON",
        "PECHEUR",
        "CHASSEUR",
        "MARCHAND",
        "AVENTURIER",
        "BATISSEUR"
      ]
    },
    "questDifficulty": {
      "type": "string",
      "enum": ["COMMON", "RARE", "LEGENDARY"]
    },
    "openMessage": { "type": "string" },
    "mainHandItem": {
      "type": "string"
    },
    "recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["result", "ingredient"],
        "properties": {
          "result": { "$ref": "#/definitions/item" },
          "ingredient": { "$ref": "#/definitions/item" },
          "message": { "type": "string" },
          "requiredReputation": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "definitions": {
    "item": {
      "type": "object",
      "properties": {
        "customItem": {
          "type": "string",
          "description": "L'identifiant de l'item personnalisé défini dans ECustomItem.java",
          "enum": [
            "FISHING_D_ROD",
            "AIR_FORCE",
            "MINEUR",
            "ENDIALE",
            "TERMINATOR",
            "SEX_ON_THE_BEACH",
            "PORN_STAR_MARTINI",
            "SHOOTER_ORGASM",
            "HEALING_ARROW",
            "SPICY_SWEET_DREAMS_TICKET",
            "CLE00",
            "CLE01",
            "CLE02",
            "CLE11",
            "CLE12",
            "CLE13",
            "CLE14",
            "CLE15",
            "CLE16",
            "CLE31",
            "CLE32",
            "GROWTH_PICKAXE",
            "GROWTH_SWORD",
            "MUFFIN",
            "UNBREAKING3",
            "MENDING",
            "CHANGER_ROLE"
          ]
        },
        "material": {
          "type": "string",
          "description": "Le nom du matériel Bukkit (ex: EMERALD, DIAMOND)",
          "examples": [
            "EMERALD",
            "DIAMOND",
            "GOLD_INGOT",
            "IRON_INGOT",
            "COAL",
            "BREAD",
            "NETHERITE_INGOT",
            "EXPERIENCE_BOTTLE"
          ]
        },
        "amount": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      },
      "oneOf": [
        { "required": ["customItem"] },
        { "required": ["material"] }
      ]
    }
  }
}
